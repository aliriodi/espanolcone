            {
                "type": "sentence-box",
                "value": "<img src='https://res.cloudinary.com/dfddh08q8/image/upload/s--aiG54j1T--/v1699321561/images/rweycoqvt0z8xqmh6cfg.png' alt='franco' /><p style= 'color: orange; padding-top:1%;padding-left:3%;'><span id='franco' style= 'color: rgba(0, 0, 0, 0); display: inline-block; border: 2px solid orange; '>____________</span></p>",
                "option": "franco",
